---
const currentYear = new Date().getFullYear();
---

<footer>
  <p>&copy; {currentYear} Jose Miguel Navarro</p>
  <p>Built with Astro.</p>
</footer>

<style>
  footer {
    flex: 0;
    background: transparent;
    display: flex;
    flex-direction: column;
    gap: 2px;
    justify-content: center;
    align-items: center;
    padding: 28px var(--page-gutter) 36px;
    margin-top: 24px;
    border-top: 1px solid var(--line);
    text-align: center;
  }
  p {
    margin: 0;
    font-size: 0.88rem;
    color: var(--text-muted);
  }
</style>
