---
interface Props {
  projectName: string;
  link?: string;
  description: string;
}

const { projectName, link, description} = Astro.props;
---

{
  link ? (
    <a
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      class="link_wrapper"
      aria-label={`Open ${projectName} project website, opens in new tab`}
    >
      <h4 class="project_title color_title">{projectName}</h4>
      <span class="project_link_arrow" aria-hidden="true">↗</span>
    </a>
  ) : (
    <div class="link_wrapper">
      <h4 class="project_title color_title">{projectName}</h4>
    </div>
  )
}
<span class="project_description">{description}</span>
<div class="content">
  <slot />
</div>

<style>
.project_title {
    text-align: left;
    margin: 0;
    font-size: clamp(1.25rem, 2vw, 1.55rem);
    letter-spacing: 0.01em;
    color: var(--text-main);
  }
  .project_description {
    font-style: normal;
    font-size: 0.96rem;
    color: var(--text-muted);
    letter-spacing: 0.01em;
  }
  .content {
    width: 100%;
    text-align: left;
    margin-top: var(--space-sm);
    color: var(--text-muted);
    max-width: 72ch;
  }
  .link_wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    width: 100%;
    transition: color 0.2s ease;
  }
  .link_wrapper .project_title {
    margin-right: 0;
  }
  .project_link_arrow {
    color: var(--brand);
    flex-shrink: 0;
    font-size: 1rem;
    line-height: 1;
    transition: transform 0.2s ease;
  }
  .link_wrapper:hover .project_title,
  .link_wrapper:focus-visible .project_title {
    color: var(--brand-strong);
  }
  .link_wrapper:hover .project_link_arrow,
  .link_wrapper:focus-visible .project_link_arrow {
    transform: translate(1px, -1px);
  }
  :global(.project-block) {
    display: grid;
    gap: var(--space-xs);
    border-top: 1px solid var(--line);
    padding-top: var(--space-lg);
  }
</style>
