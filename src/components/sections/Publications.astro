---
import { Icon } from "astro-icon/components";
import Section from "../Section.astro";
---

<Section title="technical publications" anchor="publications">
  <div class="publication_information">
    <span>Read more backend engineering articles on my Medium profile.</span>
    <a href="https://medium.com/@jmn8718" target="_blank" rel="noopener noreferrer">
      <Icon name="fa6-brands:medium" size={30} />
    </a>
  </div>
  <a
    href="https://blog.couchbase.com/graphql-server-node-couchbase-ottoman-spatial-view/"
    target="_blank"
    rel="noopener noreferrer"
  >
    <h5 class="publication_title">
      GraphQL server with Node.js, Couchbase, Ottoman, and spatial views
    </h5>
  </a>
  <span class="publication_description">
    A guide to building GraphQL APIs with Node.js and Couchbase spatial views.
  </span>
  <a
    href="https://blog.couchbase.com/develop-a-rest-api-with-couchbase-ottoman-nodejs-hapijs/"
    target="_blank"
    rel="noopener noreferrer"
  >
    <h5 class="publication_title">
      Develop a REST API with Couchbase Ottoman, Node.js, and hapi.js
    </h5>
  </a>
  <span class="publication_description">
    A tutorial on designing REST APIs with Node.js and hapi.js using Couchbase
    as the database.
  </span>
</Section>

<style>
  .publication_title {
    font-size: 1.2em;
    color: var(--text-main);
    margin-bottom: 2px;
    margin-top: 12px;
    text-align: left;
  }
  .publication_description {
    margin-bottom: 8px;
    text-align: left;
    width: 100%;
  }
  .publication_information {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: 8px;
    width: 100%;
    color: var(--text-muted);
  }
  .publication_information span {
    margin-right: 0;
    min-width: 0;
  }
</style>
