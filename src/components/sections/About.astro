---
import Section from "../Section.astro";
---

<Section title="about" anchor="home" hideTitle={true} flushTop={true} noDivider={true}>
	<div class="hero">
		<h1 data-hero-name>Jose Miguel Navarro</h1>
		<p class="lead">
			Backend software engineer focused on Node.js, TypeScript, API design, and
			scalable cloud architecture on AWS.
		</p>
	</div>
	<div class="header-sentinel" data-header-sentinel aria-hidden="true"></div>
</Section>

<style>
	:global(#home .section_content) {
		gap: clamp(1rem, 3vw, 1.5rem);
	}
	.hero {
		display: grid;
		gap: var(--space-lg);
		padding-top: clamp(1rem, 2vw, 1.5rem);
		position: relative;
		max-width: min(100%, 64rem);
	}
	.hero::after {
		content: "";
		position: absolute;
		inset-inline-end: min(2vw, 1rem);
		inset-block-start: clamp(2.5rem, 10vw, 5rem);
		inline-size: clamp(4rem, 10vw, 6rem);
		block-size: clamp(4rem, 10vw, 6rem);
		border: 1px solid rgba(99, 117, 139, 0.26);
		border-radius: 1.25rem;
		transform: rotate(10deg);
		pointer-events: none;
	}
	.header-sentinel {
		inline-size: 100%;
		block-size: 1px;
	}
	h1 {
		margin: 0;
		font-size: clamp(2.8rem, 7vw, 5rem);
		line-height: 0.98;
		letter-spacing: -0.045em;
		text-shadow: 0 1px 0 rgba(255, 255, 255, 0.55);
		white-space: nowrap;
		max-width: none;
	}
	.lead {
		margin: 0;
		font-size: clamp(1.15rem, 2.3vw, 1.45rem);
		line-height: 1.35;
		max-width: 32ch;
		color: #344553;
		color: color-mix(in srgb, var(--text-main) 82%, var(--text-muted));
	}
	@media only screen and (min-width: 840px) {
		.hero {
			padding-right: clamp(2rem, 7vw, 6rem);
		}
		.hero::after {
			inset-inline-end: 0;
		}
	}
	@media only screen and (max-width: 839px) {
		.hero::after {
			opacity: 0.55;
		}
	}
	@media only screen and (max-width: 640px) {
		h1 {
			white-space: normal;
			text-wrap: balance;
		}
		.lead {
			max-width: 100%;
		}
	}
</style>
