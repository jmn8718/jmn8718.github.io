---
import Section from "../Section.astro";
import SkillImage from "../SkillImage.astro";
---

<Section title="technical skills" anchor="skills">
  <div class="wrapper">
    <SkillImage text="NodeJS" imagePath="public/images/node.png" />
    <SkillImage text="ReactJS" imagePath="public/images/react.png" />
    <SkillImage text="Javascript" imagePath="public/images/js.png" />
    <SkillImage text="HTML" imagePath="public/images/html5.png" />
    <SkillImage text="CSS" imagePath="public/images/css.png" />
    <SkillImage text="Docker" imagePath="public/images/docker.png" />
    <SkillImage text="MongoDB" imagePath="public/images/mongo.png" />
    <SkillImage text="PostgreSQL" imagePath="public/images/postgre.png" />
    <SkillImage text="Redis" imagePath="public/images/redis.png" />
    <SkillImage text="Github" imagePath="public/images/github.png" />
    <SkillImage text="AWS" imagePath="public/images/aws.png" />
  </div>
</Section>

<style>
  .wrapper {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    gap: 16px;
  }
</style>
