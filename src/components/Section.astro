---
interface Props {
	title: string;
	anchor?: string;
	hideTitle?: boolean;
	flushTop?: boolean;
	noDivider?: boolean;
}

const { title, anchor, hideTitle = false, flushTop = false, noDivider = false } = Astro.props;
---
<section
	class="section_container"
	id={anchor}
	data-flush-top={flushTop ? "true" : undefined}
>
	<div class="section_shell">
		{!hideTitle && <h2>{title}</h2>}
		<div class="section_content" data-no-divider={noDivider ? "true" : undefined}>
			<slot />
		</div>
	</div>
</section>
<style>
	h2 {
		margin: 0;
		padding: 0;
		font-size: clamp(1.05rem, 1.8vw, 1.3rem);
		font-weight: 800;
		color: var(--brand-strong);
		text-transform: uppercase;
		display: grid;
		grid-template-columns: auto minmax(2.5rem, 8rem);
		align-items: center;
		column-gap: clamp(0.75rem, 2vw, 1.5rem);
		max-width: min(100%, 34rem);
		text-align: left;
		letter-spacing: 0.18em;
	}
	h2::after {
		content: "";
		display: block;
		inline-size: 100%;
		block-size: 1px;
		transform: translateY(1px);
		background:
			linear-gradient(90deg, var(--brand-strong) 0 42%, color-mix(in srgb, var(--accent) 72%, transparent) 100%);
	}

	.section_container {
		width: 100%;
		padding: clamp(2.5rem, 6vw, 5rem) 0 0;
	}
	.section_container[data-flush-top="true"] {
		padding-top: 0;
	}
	.section_shell {
		width: min(100%, calc(var(--content-max-width) + var(--page-gutter) * 2));
		margin: 0 auto;
		padding: 0 var(--page-gutter);
		display: grid;
		gap: clamp(1rem, 2.5vw, var(--space-lg));
	}
	.section_content {
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
		padding-top: var(--space-sm);
		min-width: 0;
	}
	.section_content[data-no-divider="true"] {
		padding-top: 0;
	}
	@media only screen and (max-width: 640px) {
		h2 {
			grid-template-columns: 1fr;
			row-gap: var(--space-sm);
			max-width: 100%;
		}
	}
</style>
