---
interface Props {
	title: string;
	anchor?: string;
}

const { title, anchor } = Astro.props;
---
<section class="section_container" id={anchor}>
	<div class="section_shell">
		<h2>{title}</h2>
		<div class="section_content">
			<slot />
		</div>
	</div>
</section>
<style>
	h2 {
		margin: 0 0 12px 0;
		padding: 0;
		font-size: clamp(1.45rem, 4vw, 2.1rem);
		font-weight: 700;
		color: var(--text-main);
		text-transform: uppercase;
		display: block;
		text-align: left;
		letter-spacing: 0.06em;
	}

	.section_container {
		width: 100%;
		padding: 86px 0 0;
		margin-bottom: 24px;
	}
	.section_shell {
		width: min(100%, calc(var(--content-max-width) + var(--page-gutter) * 2));
		margin: 0 auto;
		padding: 0 var(--page-gutter);
	}
	.section_content {
		padding: 22px 22px 26px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 14px;
		background: var(--surface-elevated);
		border: 1px solid var(--line);
		border-radius: 18px;
		box-shadow: var(--shadow);
	}
	@media only screen and (max-width: 640px) {
		.section_content {
			padding: 18px 16px 22px;
		}
	}
</style>
