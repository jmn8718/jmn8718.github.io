---
interface Props {
	title: string;
	anchor?: string;
	hideTitle?: boolean;
	flushTop?: boolean;
	noDivider?: boolean;
}

const { title, anchor, hideTitle = false, flushTop = false, noDivider = false } = Astro.props;
---
<section
	class="section_container"
	id={anchor}
	data-flush-top={flushTop ? "true" : undefined}
>
	<div class="section_shell">
		{!hideTitle && <h2>{title}</h2>}
		<div class="section_content" data-no-divider={noDivider ? "true" : undefined}>
			<slot />
		</div>
	</div>
</section>
<style>
	h2 {
		position: relative;
		margin: 0;
		padding: 0 0 var(--space-xs);
		font-size: clamp(1.15rem, 2vw, 1.45rem);
		font-weight: 800;
		color: var(--text-main);
		text-transform: uppercase;
		display: inline-block;
		inline-size: fit-content;
		max-width: 100%;
		text-align: left;
		letter-spacing: 0.14em;
	}
	h2::after {
		content: "";
		display: block;
		inline-size: 100%;
		block-size: 0.22rem;
		margin-top: var(--space-sm);
		border-radius: 999px;
		background: linear-gradient(90deg, var(--brand), var(--accent));
	}

	.section_container {
		width: 100%;
		padding: clamp(2.5rem, 6vw, 5rem) 0 0;
	}
	.section_container[data-flush-top="true"] {
		padding-top: 0;
	}
	.section_shell {
		width: min(100%, calc(var(--content-max-width) + var(--page-gutter) * 2));
		margin: 0 auto;
		padding: 0 var(--page-gutter);
		display: grid;
		gap: var(--space-lg);
	}
	.section_content {
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
		padding-top: var(--space-sm);
		min-width: 0;
	}
	.section_content[data-no-divider="true"] {
		padding-top: 0;
	}
</style>
