---
interface Props {
	text: string;
  imagePath: string;
  width?: number;
  height?: number;
}

const { imagePath, text, width = 40, height = 40 } = Astro.props;
---

<style>
  .skill-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    border: 1px solid var(--line);
    background: #f8f8f4;
    background: color-mix(in srgb, var(--surface-elevated) 92%, var(--surface-soft));
    border-radius: 14px;
    padding: var(--space-md) var(--space-sm);
    min-height: 122px;
    min-width: 0;
  }
  .skill-image {
    width: auto;
    height: 40px;
    object-fit: contain;
  }
  .skill-text {
    font-weight: 700;
    font-size: 0.86rem;
    text-align: center;
    color: var(--text-main);
    max-width: 100%;
    overflow-wrap: anywhere;
    text-wrap: balance;
    line-height: 1.25;
  }
</style>

<div class="skill-wrapper">
  <img class="skill-image" src={imagePath} alt={text} loading="lazy" width={width} height={height} />
  <span class="skill-text">{text}</span>
</div>
