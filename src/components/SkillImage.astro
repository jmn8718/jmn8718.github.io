---
interface Props {
	text: string;
  imagePath: string
}

const { imagePath, text } = Astro.props;
---

<style>
  .skill-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: 14px;
    padding: 14px 10px;
    min-height: 122px;
  }
  .skill-image {
    width: auto;
    height: 40px;
    object-fit: contain;
  }
  .skill-text {
    font-weight: 700;
    font-size: 0.88rem;
    text-align: center;
    color: var(--text-main);
  }
</style>

<div class="skill-wrapper">
  <img class="skill-image" src={imagePath} alt={text} loading="lazy" />
  <span class="skill-text">{text}</span>
</div>
