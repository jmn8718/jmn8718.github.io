---
interface Props {
  companyName: string;
  link?: string;
  period: string;
  location: string;
  role: string;
}

const { companyName, link, period, location, role } = Astro.props;
---

<div class="wrapper">
  {
    link ? (
      <a href={link} target="_blank" rel="noopener noreferrer">
        <h3 class="title color_title">{companyName}</h3>
      </a>
    ) : (
      <h3 class="title color_title">{companyName}</h3>
    )
  }
  <div class="information">
    <p>
      <strong>Role</strong>
       : {role}
    </p>
    <p>
      <strong>Location</strong>
       : {location}
    </p>
    <p>
      <strong>Period</strong>
       : {period}
    </p>
  </div>
  <div class="content">
    <slot />
  </div>
</div>

<style>
  .wrapper {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
    border: 1px solid var(--line);
    background: var(--surface);
    border-radius: 14px;
    padding: 16px;
    margin-bottom: 14px;
  }
  .title {
    text-align: left;
    margin: 0 0 8px;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    letter-spacing: 0.02em;
    color: var(--text-main);
  }
  .information {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    width: 100%;
    border-top: 1px dashed var(--line);
    border-bottom: 1px dashed var(--line);
    padding: 8px 0;
  }
  .information p {
    margin: 0;
    font-size: 0.92rem;
  }
  .content {
    margin-top: 16px;
    color: var(--text-muted);
  }

  @media screen and (max-width: 640px) {
    .information {
      flex-direction: column;
      gap: 6px;
    }
    .information p {
      margin: 0;
    }
  }
</style>
