---
interface Props {
  companyName: string;
  link?: string;
  period: string;
  location: string;
  role: string;
}

const { companyName, link, period, location, role } = Astro.props;
---

<div class="wrapper">
  {
    link ? (
      <a href={link} target="_blank" rel="noopener noreferrer" aria-label={`${companyName}, opens in new tab`}>
        <h3 class="title color_title">{companyName}</h3>
      </a>
    ) : (
      <h3 class="title color_title">{companyName}</h3>
    )
  }
  <dl class="information">
    <div class="meta_row">
      <dt>Role</dt>
      <dd>{role}</dd>
    </div>
    <div class="meta_row">
      <dt>Location</dt>
      <dd>{location}</dd>
    </div>
    <div class="meta_row">
      <dt>Period</dt>
      <dd>{period}</dd>
    </div>
  </dl>
  <div class="content">
    <slot />
  </div>
</div>

<style>
  .wrapper {
    display: grid;
    gap: var(--space-sm);
    width: 100%;
    border-top: 1px solid var(--line);
    padding-top: var(--space-lg);
  }
  .title {
    text-align: left;
    margin: 0;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    letter-spacing: 0.02em;
    color: var(--text-main);
  }
  .information {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    width: 100%;
    padding: 0;
    margin: 0;
  }
  .meta_row {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    min-width: 0;
  }
  .information dt {
    margin: 0;
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--text-main);
  }
  .information dt::after {
    content: ":";
    margin-left: 0.04em;
  }
  .information dd {
    margin: 0;
    font-size: 0.92rem;
    min-width: 0;
    color: var(--text-muted);
    overflow-wrap: anywhere;
  }
  .content {
    margin-top: var(--space-xs);
    color: var(--text-muted);
    max-width: 72ch;
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .content :global(p) {
    margin: 0;
  }
  .content :global(p + p) {
    margin-top: var(--space-sm);
  }

  @media screen and (min-width: 920px) {
    .wrapper {
      grid-template-columns: minmax(220px, 0.42fr) minmax(0, 1fr);
      align-items: start;
      column-gap: var(--space-xl);
      row-gap: var(--space-xs);
    }
    .title,
    .information {
      grid-column: 1;
    }
    .content {
      grid-column: 2;
      grid-row: 1 / span 2;
      margin-top: 0;
    }
    .information {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
  @media screen and (max-width: 640px) {
    .information {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
</style>
